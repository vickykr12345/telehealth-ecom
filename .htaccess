RewriteEngine On

# If the request is for an existing file/folder, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Home
RewriteRule ^$ index.php [L]

# Direct access to specific PHP files (bypass router for these)
RewriteRule ^(doctors|profile|checkout|thankyou|terms-new)/?$ $1.php [QSA,L]

# All other pages go through router for pretty URLs
RewriteRule ^([A-Za-z0-9-]+)/?$ router.php?path=$1 [QSA,L]

